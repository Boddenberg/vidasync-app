# Backend principal (auth, meals, favorites, nutrition texto/foto)
EXPO_PUBLIC_API_BASE_URL=https://vidasync-bff-production.up.railway.app

# Projeto 1: endpoint de audio (opcional; se vazio usa API_BASE_URL)
EXPO_PUBLIC_API_AUDIO_BASE_URL=
EXPO_PUBLIC_API_NUTRITION_AUDIO_PATH=/nutrition/calories/audio

# Projeto 2: endpoint de PDF/plano (opcional; se vazio usa API_BASE_URL)
EXPO_PUBLIC_API_PLAN_BASE_URL=
EXPO_PUBLIC_API_PLAN_PDF_PATH=/plans/pdf/analyze

# Projeto 3: endpoint de confirmacao de revisao (opcional; se vazio usa API_BASE_URL)
EXPO_PUBLIC_API_REVIEW_BASE_URL=
EXPO_PUBLIC_API_REVIEW_CONFIRM_PATH=/review/confirm

# Upload opcional para transformar arquivo local/base64 em URL publica.
# Com API_REQUIRE_REMOTE_FILE_URL=true, foto/audio/PDF sera enviado por link.
EXPO_PUBLIC_API_UPLOAD_BASE_URL=https://vidasync-bff-production.up.railway.app
EXPO_PUBLIC_API_UPLOAD_PATH=/uploads/presign
EXPO_PUBLIC_API_REQUIRE_REMOTE_FILE_URL=true

# Chave opcional para liberar o painel interno/admin de feedback no app.
# Use apenas em builds internas controladas.
EXPO_PUBLIC_INTERNAL_ADMIN_API_KEY=
EXPO_PUBLIC_INTERNAL_ADMIN_USER_ID=
EXPO_PUBLIC_INTERNAL_ADMIN_JUDGE_FEATURE=chat

# Supabase publico para a dashboard de desenvolvedor ler as avaliacoes
# de LLM-as-a-judge via PostgREST, usando o access token do usuario.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_JUDGE_TABLE=llm_judge_evaluations
EXPO_PUBLIC_SUPABASE_JUDGE_FEATURE=chat
EXPO_PUBLIC_SUPABASE_JUDGE_LIMIT=50
